<body name="robot_parts">
  <joint name="robot_x" type="slide" axis="1 0 0" limited="true" range="-0.15 1.35" damping="5"/>
  <joint name="robot_y" type="slide" axis="0 1 0" limited="true" range="-0.55 0.25" damping="5"/>

  <geom name="robot_base" type="box" pos="0 0 0" size="0.18 0.12 0.06" material="robot_body" mass="5"/>
  <geom name="robot_bumper" type="box" pos="0.17 0 0" size="0.025 0.13 0.045" material="robot_dark" mass="0.5"/>

  <body name="mast" pos="0.12 0 0.06">
    <geom name="mast_geom" type="box" pos="0 0 0.055" size="0.025 0.025 0.055" material="robot_dark" mass="0.3"/>

    <body name="arm_lift_body" pos="0 0 0.13">
      <joint name="arm_lift" type="slide" axis="0 0 1" limited="true" range="0 0.10" damping="4"/>
      <geom name="arm_bar" type="box" pos="0.13 0 0" size="0.15 0.02 0.02" material="arm" mass="0.4"/>

      <body name="gripper" pos="0.28 0 0">
        <geom name="gripper_palm" type="box" pos="0 0 0" size="0.025 0.055 0.025" material="arm" mass="0.2"/>
        <site name="gripper_site" pos="0.055 0 0" size="0.018" rgba="0.1 0.5 1 1"/>
        <site name="gripper_touch_site" pos="0.055 0 0" type="sphere" size="0.09" rgba="0.1 0.5 1 0.12"/>

        <body name="left_finger" pos="0.045 0.045 0">
          <joint name="left_finger" type="slide" axis="0 -1 0" limited="true" range="0 0.025" damping="2"/>
          <geom name="left_finger_geom" type="box" pos="0.025 0 0" size="0.045 0.008 0.032" material="finger" mass="0.08"/>
        </body>

        <body name="right_finger" pos="0.045 -0.045 0">
          <joint name="right_finger" type="slide" axis="0 1 0" limited="true" range="0 0.025" damping="2"/>
          <geom name="right_finger_geom" type="box" pos="0.025 0 0" size="0.045 0.008 0.032" material="finger" mass="0.08"/>
        </body>
      </body>
    </body>
  </body>
</body>
