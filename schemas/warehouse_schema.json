{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentech.local/schemas/warehouse/warehouse_schema.json",
  "title": "Outbound Tile-Based Warehouse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "warehouse_id",
    "warehouse_size",
    "movement_rules",
    "tile_map",
    "tile_neighbors",
    "rack_map",
    "sku_catalog",
    "rack_inventory",
    "outbound_conveyors"
  ],
  "properties": {
    "warehouse_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "warehouse_size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width_tiles", "height_tiles"],
      "properties": {
        "width_tiles": {
          "type": "integer",
          "minimum": 1
        },
        "height_tiles": {
          "type": "integer",
          "minimum": 1
        },
        "tile_size_m": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 1.0
        }
      }
    },
    "movement_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "movement_model",
        "lock_model",
        "allow_diagonal_moves",
        "allowed_directions",
        "visual_projection"
      ],
      "properties": {
        "movement_model": {
          "type": "string",
          "const": "four_direction_grid"
        },
        "lock_model": {
          "type": "string",
          "const": "current_and_next_tile"
        },
        "allow_diagonal_moves": {
          "type": "boolean",
          "const": false
        },
        "allowed_directions": {
          "type": "array",
          "const": ["N", "S", "E", "W"],
          "description": "Only cardinal grid moves are valid. Isometric rendering may display these as 45-degree screen moves."
        },
        "visual_projection": {
          "type": "string",
          "const": "isometric"
        }
      }
    },
    "tile_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tile"
      }
    },
    "tile_neighbors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tile_neighbor"
      },
      "description": "N/S/E/W connectivity graph. No diagonal edges."
    },
    "occupancy_map": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/occupancy"
      }
    },
    "rack_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rack"
      }
    },
    "sku_catalog": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sku"
      }
    },
    "rack_inventory": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rack_inventory"
      }
    },
    "outbound_conveyors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/outbound_conveyor"
      }
    },
    "outbound_docks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outbound_dock"
      }
    },
    "truck_schedules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/truck_schedule"
      }
    },
    "order_generation_profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/order_generation_profile"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "tile_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tile_id", "x", "y"],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "x": {
          "type": "integer",
          "minimum": 0
        },
        "y": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "tile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tile_id",
        "x",
        "y",
        "tile_type",
        "is_available_floor",
        "is_traversable",
        "blocks_robot",
        "collision_class"
      ],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "x": {
          "type": "integer",
          "minimum": 0
        },
        "y": {
          "type": "integer",
          "minimum": 0
        },
        "tile_type": {
          "type": "string",
          "enum": [
            "floor",
            "rack_occupied",
            "pick_point",
            "conveyor",
            "dock",
            "wall",
            "blocked",
            "charger"
          ]
        },
        "is_traversable": {
          "type": "boolean",
          "description": "Compatibility alias for pathfinding. Should match is_available_floor."
        },
        "is_available_floor": {
          "type": "boolean",
          "description": "Authoritative flag for whether a robot may stand on or move through this tile."
        },
        "blocks_robot": {
          "type": "boolean",
          "description": "True for rack, conveyor, dock, wall, and blocked tiles."
        },
        "collision_class": {
          "type": "string",
          "enum": [
            "available_floor",
            "rack_collision",
            "conveyor_collision",
            "dock_collision",
            "wall_collision",
            "temporary_blocked",
            "charger_floor"
          ]
        },
        "is_pick_point": {
          "type": "boolean",
          "default": false
        },
        "is_outbound_point": {
          "type": "boolean",
          "default": false
        },
        "base_travel_cost": {
          "type": "number",
          "minimum": 0,
          "default": 1
        },
        "current_robot_id": {
          "type": ["string", "null"]
        },
        "current_lock_id": {
          "type": ["string", "null"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "tile_type": {
                "enum": ["floor", "pick_point"]
              }
            },
            "required": ["tile_type"]
          },
          "then": {
            "properties": {
              "is_available_floor": {
                "const": true
              },
              "is_traversable": {
                "const": true
              },
              "blocks_robot": {
                "const": false
              },
              "collision_class": {
                "const": "available_floor"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "tile_type": {
                "const": "charger"
              }
            },
            "required": ["tile_type"]
          },
          "then": {
            "properties": {
              "is_available_floor": {
                "const": true
              },
              "is_traversable": {
                "const": true
              },
              "blocks_robot": {
                "const": false
              },
              "collision_class": {
                "const": "charger_floor"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "tile_type": {
                "const": "rack_occupied"
              }
            },
            "required": ["tile_type"]
          },
          "then": {
            "properties": {
              "is_available_floor": {
                "const": false
              },
              "is_traversable": {
                "const": false
              },
              "blocks_robot": {
                "const": true
              },
              "collision_class": {
                "const": "rack_collision"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "tile_type": {
                "const": "conveyor"
              }
            },
            "required": ["tile_type"]
          },
          "then": {
            "properties": {
              "is_available_floor": {
                "const": false
              },
              "is_traversable": {
                "const": false
              },
              "blocks_robot": {
                "const": true
              },
              "collision_class": {
                "const": "conveyor_collision"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "tile_type": {
                "const": "dock"
              }
            },
            "required": ["tile_type"]
          },
          "then": {
            "properties": {
              "is_available_floor": {
                "const": false
              },
              "is_traversable": {
                "const": false
              },
              "blocks_robot": {
                "const": true
              },
              "collision_class": {
                "const": "dock_collision"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "tile_type": {
                "const": "wall"
              }
            },
            "required": ["tile_type"]
          },
          "then": {
            "properties": {
              "is_available_floor": {
                "const": false
              },
              "is_traversable": {
                "const": false
              },
              "blocks_robot": {
                "const": true
              },
              "collision_class": {
                "const": "wall_collision"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "tile_type": {
                "const": "blocked"
              }
            },
            "required": ["tile_type"]
          },
          "then": {
            "properties": {
              "is_available_floor": {
                "const": false
              },
              "is_traversable": {
                "const": false
              },
              "blocks_robot": {
                "const": true
              },
              "collision_class": {
                "const": "temporary_blocked"
              }
            }
          }
        }
      ]
    },
    "tile_neighbor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_tile_id", "to_tile_id", "direction", "is_enabled"],
      "description": "Only connects available floor tiles. Do not create edges into rack, conveyor, dock, wall, or blocked tiles.",
      "properties": {
        "from_tile_id": {
          "type": "string",
          "minLength": 1
        },
        "to_tile_id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "enum": ["N", "S", "E", "W"]
        },
        "is_enabled": {
          "type": "boolean",
          "default": true
        },
        "travel_cost": {
          "type": "number",
          "minimum": 0,
          "default": 1
        }
      }
    },
    "occupancy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tile_id"],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "robot_id": {
          "type": ["string", "null"]
        },
        "package_id": {
          "type": ["string", "null"]
        },
        "active_lock_id": {
          "type": ["string", "null"]
        },
        "lock_type": {
          "type": ["string", "null"],
          "enum": [
            "current_tile",
            "next_tile",
            "pick_point",
            "handoff_pair",
            "conveyor_unload",
            null
          ]
        }
      }
    },
    "rack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rack_id",
        "anchor_tile",
        "footprint_width_tiles",
        "footprint_length_tiles",
        "orientation",
        "rack_tiles",
        "pick_points",
        "status"
      ],
      "properties": {
        "rack_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "anchor_tile": {
          "$ref": "#/$defs/tile_ref"
        },
        "footprint_width_tiles": {
          "type": "integer",
          "const": 1
        },
        "footprint_length_tiles": {
          "type": "integer",
          "enum": [2, 3]
        },
        "orientation": {
          "type": "string",
          "enum": ["N", "S", "E", "W"]
        },
        "rack_tiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rack_tile"
          }
        },
        "pick_points": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rack_pick_point"
          }
        },
        "status": {
          "type": "string",
          "enum": ["active", "blocked", "empty", "maintenance"]
        }
      }
    },
    "rack_tile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tile_id", "segment_index"],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "segment_index": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rack_pick_point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pick_point_id",
        "rack_tile_id",
        "tile_id",
        "side",
        "is_available"
      ],
      "properties": {
        "pick_point_id": {
          "type": "string",
          "minLength": 1
        },
        "rack_tile_id": {
          "type": "string",
          "minLength": 1
        },
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "side": {
          "type": "string",
          "enum": ["left", "right"]
        },
        "is_available": {
          "type": "boolean"
        },
        "blocked_reason": {
          "type": ["string", "null"],
          "enum": ["wall", "blocked_tile", "maintenance", "none", null]
        }
      }
    },
    "sku": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sku_id",
        "name",
        "weight_class",
        "package_visual_type",
        "unit_weight",
        "handling_difficulty"
      ],
      "properties": {
        "sku_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "weight_class": {
          "type": "string",
          "enum": ["light", "medium", "heavy"]
        },
        "package_visual_type": {
          "type": "string",
          "enum": ["cardboard_box", "wooden_crate", "metal_crate"]
        },
        "unit_weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "unit_volume": {
          "type": "number",
          "minimum": 0
        },
        "handling_difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        },
        "pick_base_ticks": {
          "type": "integer",
          "minimum": 1
        },
        "transfer_base_ticks": {
          "type": "integer",
          "minimum": 1
        },
        "unload_base_ticks": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"],
          "default": "active"
        }
      }
    },
    "rack_inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rack_inventory_id",
        "rack_id",
        "sku_id",
        "initial_quantity",
        "available_quantity",
        "reserved_quantity",
        "picked_quantity",
        "shipped_quantity"
      ],
      "properties": {
        "rack_inventory_id": {
          "type": "string",
          "minLength": 1
        },
        "rack_id": {
          "type": "string",
          "minLength": 1
        },
        "sku_id": {
          "type": "string",
          "minLength": 1
        },
        "preferred_pick_point_id": {
          "type": ["string", "null"]
        },
        "initial_quantity": {
          "type": "integer",
          "minimum": 0
        },
        "available_quantity": {
          "type": "integer",
          "minimum": 0
        },
        "reserved_quantity": {
          "type": "integer",
          "minimum": 0
        },
        "picked_quantity": {
          "type": "integer",
          "minimum": 0
        },
        "shipped_quantity": {
          "type": "integer",
          "minimum": 0
        },
        "last_updated_tick": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "outbound_conveyor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["conveyor_id", "conveyor_tile_id", "dropoff_tile", "status"],
      "properties": {
        "conveyor_id": {
          "type": "string",
          "minLength": 1
        },
        "dock_id": {
          "type": ["string", "null"]
        },
        "conveyor_tile_id": {
          "type": "string",
          "minLength": 1,
          "description": "The conveyor body tile. It should not be available floor."
        },
        "dropoff_tile": {
          "$ref": "#/$defs/tile_ref",
          "description": "Available floor tile where the robot stands to unload onto the conveyor."
        },
        "queue_capacity_orders": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["active", "congested", "blocked", "maintenance"]
        }
      }
    },
    "outbound_dock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dock_id", "dock_tile", "status"],
      "properties": {
        "dock_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "dock_tile": {
          "$ref": "#/$defs/tile_ref"
        },
        "status": {
          "type": "string",
          "enum": ["active", "closed", "congested", "maintenance"]
        }
      }
    },
    "truck_schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schedule_id",
        "dock_id",
        "frequency_minutes",
        "first_arrival_tick",
        "loading_window_ticks",
        "capacity_orders",
        "status"
      ],
      "properties": {
        "schedule_id": {
          "type": "string",
          "minLength": 1
        },
        "dock_id": {
          "type": "string",
          "minLength": 1
        },
        "frequency_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "first_arrival_tick": {
          "type": "integer",
          "minimum": 0
        },
        "loading_window_ticks": {
          "type": "integer",
          "minimum": 1
        },
        "capacity_orders": {
          "type": "integer",
          "minimum": 1
        },
        "capacity_weight": {
          "type": "number",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "retired"]
        }
      }
    },
    "order_generation_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "orders_per_minute",
        "sku_distribution",
        "deadline_distribution"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "minLength": 1
        },
        "orders_per_minute": {
          "type": "number",
          "minimum": 0
        },
        "burst_factor": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "sku_distribution": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          }
        },
        "quantity_distribution": {
          "type": "object",
          "additionalProperties": true
        },
        "priority_distribution": {
          "type": "object",
          "additionalProperties": true
        },
        "deadline_distribution": {
          "type": "object",
          "additionalProperties": true
        },
        "random_seed": {
          "type": "integer"
        },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "completed"],
          "default": "active"
        }
      }
    }
  }
}
